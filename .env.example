# ── FHIR source ──────────────────────────────────────────
FHIR_CODESYSTEM_URL=https://your-fhir-server.example/fhir/CodeSystem/your-codesystem
CODESYSTEM_CANONICAL_URL=https://your-org.example/fhir/CodeSystem/lab-analyses

# ── Poll schedule (cron expression) ─────────────────────
# Default: every 4 hours
POLL_CRON=0 */4 * * *

# ── Hashing strategy ────────────────────────────────────
# Set to "true" if the FHIR server returns non-deterministic JSON
# (field order or whitespace changes between identical responses)
CANONICAL_HASH=false

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=poller
POSTGRES_PASSWORD=change-me
POSTGRES_DB=codesystem_poller
DATABASE_URL=postgresql://poller:change-me@db:5432/codesystem_poller

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me
RABBITMQ_URL=amqp://guest:change-me@rabbitmq:5672/
RABBITMQ_EXCHANGE=codesystem.changes

# ── Outbox relay ─────────────────────────────────────────
OUTBOX_POLL_INTERVAL=5

# ── General ──────────────────────────────────────────────
LOG_LEVEL=INFO
HTTP_TIMEOUT=30
